{
    "layer": "top",
    "position": "top",
    "height": 5,
    "spacing": 5,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": -5,

    "modules-left": [
        "custom/arch",
        "hyprland/workspaces"
    ],

    "modules-center": [
        "clock#time",
        "clock#date"
    ],

    "modules-right": [
        "tray",
        "pulseaudio",
        "custom/powermenu"
    ],

    "custom/arch": {
        "format": "󰣇",
        "tooltip": false,
        "on-click": "rofi -show drun"
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5, 6, 7]
        },
        "on-click": "activate",
        "sort-by-number": true
    },

    "clock#time": {
        "format": "󰥔 {:%H:%M}",
        "tooltip": false
    },

    "clock#date": {
        "format": "󰃭 {:%d %b %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "format": {
                "months": "<span color='#5DBB63'><b>{}</b></span>",
                "days": "<span color='#C5C8C6'>{}</span>",
                "weeks": "<span color='#FFCB6B'>W{}</span>",
                "weekdays": "<span color='#8de05d'><b>{}</b></span>",
                "today": "<span color='#c8f5a0'><b><u>{}</u></b></span>"
            }
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "headphone": "󰋋",
            "headset": "󰋎",
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "scroll-step": 5,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip-format": "{desc}\n{volume}%",
        "smooth-scrolling-threshold": 1
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    },

    "custom/powermenu": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "bash -c 'case $(echo -e \"  Shutdown\n  Reboot\n  Suspend\n  Lock\n󰍃  Logout\" | rofi -dmenu -p \"Power\" -i) in\n\"  Shutdown\") systemctl poweroff;;\n\"  Reboot\") systemctl reboot;;\n\"  Suspend\") systemctl suspend;;\n\"  Lock\") loginctl lock-session;;\n\"󰍃  Logout\") loginctl terminate-user $USER;;\nesac'"
    }
}
